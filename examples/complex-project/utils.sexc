(include "stdio.h")

(defn void print-header ()
  (printf "\n=== Complex Project Demo ===\n"))

(defn void print-step ((int step) (Counter c))
  (printf
    "step=%d total=%d count=%d avg=%.2f\n"
    step
    (. c total)
    (. c count)
    (Counter/average c)))

(defn void print-summary ((Counter c))
  (printf
    "summary: total=%d count=%d avg=%.2f\n"
    (. c total)
    (. c count)
    (Counter/average c)))
