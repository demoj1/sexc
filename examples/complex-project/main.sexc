(include "stdio.h")

(%import "./lib.sexc")
(%import "./utils.sexc")

(defn int main ()
  (decl (stats/Counter c) (stats/Counter# 0))

  (utils/print-header)

  (for-range i 1 8
    (decl (int raw-score) (+ (* i i) 7))
    (decl (int score) (stats/clamp-int raw-score 0 40))
    (set c (stats/Counter/add c score))
    (utils/print-step i c))

  (utils/print-summary c)
  (return 0))
