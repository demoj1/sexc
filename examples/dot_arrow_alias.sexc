(include "stdio.h")

(struct Vec2
  :fields
  (float x)
  (float y))

(struct Transform
  :fields
  (Vec2 position))

(struct Player
  :fields
  (Transform location))

(defn int main ()
  (decl (Player p) (zero-init))
  (set (. p location position x) 10.0
       (. p location position y) 20.0)

  (decl (:* Player pp) (%addr p))

  (printf "%f %f\n" (. p location position x) (. (-> pp location) position y))
  (return 0))
