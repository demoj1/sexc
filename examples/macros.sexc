(%import "../std/core.sexc")

(include "stdio.h")

(%defmacro banner-defines ()
  `(%top-level-splice
     (define APP_NAME "macro demo")
     (define APP_VERSION 2)))

(%defmacro twice (form)
  `(%block ,form ,form))

(banner-defines)

(defn int main ()
  (decl (int x) 0)
  (when (= x 0)
    (printf "%s v%d\n" APP_NAME APP_VERSION))
  (incf x)
  (unless (= x 0)
    (printf "x is now %d\n" x))
  (twice (printf "twice!\n"))
  (return 0))
