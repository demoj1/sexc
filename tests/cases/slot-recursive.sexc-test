; A recursive consumer must not loop the analysis (call-graph fixpoint); its
; requirement still reaches main.
(include <stdio.h>)
(defn void countdown ((int n))
  (slot* *out*)
  (fprintf *out* "%d\n" n)
  (when (> n 0) (countdown (- n 1))))
(defn int main ()
  (countdown 3)
  (return 0))
;==EXPECTED-ERROR==
<stdin>:9:4: error[analysis]: countdown requires the dynamic slot *out*, which is unbound here — provide it before the call with (with *out* <value> ...)
  (countdown 3)
   ^
