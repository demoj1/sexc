; nil / %null -> ((void*)0); if-nil branches on a null pointer via `if`.
(defn int demo (((%ptr int) p))
  (set p nil)
  (set p (%null))
  (if-nil p
    (return 1)
    (return (%deref p)))
  (if-nil p (return 0)))
;==EXPECTED==
int demo(int *p)
{
  p = ((void*)0);
  p = ((void*)0);
  if (p == ((void*)0))
    {
      return 1;
    }
  else
    {
      return *p;
    }
  if (p == ((void*)0))
    {
      return 0;
    }
}
