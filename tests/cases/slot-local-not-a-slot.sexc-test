; A plain local that merely happens to be earmuffed is NOT a dynamic slot — no
; `with` or `slot*` ever makes it one — so it is never flagged.
(include <stdio.h>)
(defn int main ()
  (decl (int *foobar*) 5)
  (printf "%d\n" *foobar*)
  (return 0))
;==EXPECTED==
#include <stdio.h>

int main(void)
{
  int _u002A_foobar_u002A_ = 5;
  printf("%d\n", _u002A_foobar_u002A_);
  return 0;
}
