(%def-fn int sum-to ((int n))
  (%block
    (%decl int total 0)
    (%for (%decl int i 0) (< i n) (%set i (+ i 1))
      (%set total (+ total i)))
    (%return total)))
;==EXPECTED==
int sum_u002D_to(int n)
{
  int total = 0;
  for (int i = 0; i < n; i = i + 1)
    total = total + i;
  return total;
}
