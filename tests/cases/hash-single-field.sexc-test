; Type# with a single designated field; zero via (Type#) or (zero-init).
(struct One :fields (int x))

(defn int main ()
  (decl (One a) (One# :x 5)
        (One z) (zero-init))
  (return (+ (. a x) (. z x))))
;==EXPECTED==
typedef struct One {
  int x;
} One;

int main(void)
{
  One a = (One){.x = 5};
  One z = {0};
  return a.x + z.x;
}
