(%def-fn int find-first-even (((%ptr int) arr) (int n))
  (%block
    (%for (%decl int i 0) (< i n) (%set i (+ i 1))
      (%if (= (%% (%aref arr i) 2) 0)
        (%return (%aref arr i))
        (%continue)))
    (%return -1)))
;==EXPECTED==
int find_u002D_first_u002D_even(int *arr, int n)
{
  for (int i = 0; i < n; i = i + 1)
    if (arr[i] % 2 == 0)
      return arr[i];
    else
      continue;
  return -1;
}
