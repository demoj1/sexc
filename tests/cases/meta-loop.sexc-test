; $loop / $recur — compile-time tail loop. Here it unrolls a list of statements at
; macro time (sum baked into a #define, printfs generated by accumulating a list).
(define SUM10 (%eval ($loop ((i 10) (acc 0))
  ($if ($zero? i) acc ($recur ($- i 1) ($+ acc i))))))
(defn int main ()
  (%evals ($loop ((k 1) (acc ($list)))
    ($if ($eq? k 4)
      ($reverse acc)
      ($recur ($+ k 1) ($cons `(printf "%d\n" ,k) acc)))))
  (printf "sum=%d\n" SUM10)
  (return 0))
;==EXPECTED==
#define SUM10 55

int main(void)
{
  printf("%d\n", 1);
  printf("%d\n", 2);
  printf("%d\n", 3);
  printf("sum=%d\n", SUM10);
  return 0;
}
