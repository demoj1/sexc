; A bundled field/param name that collides with a module symbol must stay a name
; (only the base type is qualified). The post-expansion %-IR pass (qualify_ir)
; protects name positions (%struct field names, %arrow field) while qualifying
; the type, so the field/param `data` is untouched but `(defn data ...)` becomes
; m/data.
(%module m)
(struct N :fields (:* float data) (int n))   ; field 'data' == the fn below
(defn int data () (return 0))
(defn float head ((:* N p)) (return (aref (-> p data) 0)))
;==EXPECTED==
typedef struct m_u002F_N {
  float *data;
  int n;
} m_u002F_N;

int m_u002F_data(void)
{
  return 0;
}

float m_u002F_head(m_u002F_N *p)
{
  return (p->data)[0];
}
