; defsum inside a %module: every generated name (tag enum + constants, payload
; structs, the sum struct, predicates, the area fn) is module-qualified to geo/…,
; and the match references (tag constants, the type) line up. defsum bakes the
; qualified names itself (enum variants are name-protected by the %-IR pass) and
; is registered in collect_module_defined_names so user type refs qualify too.
(%module geo)
(defsum Shape (Circle (float r)) (Rect (float w) (float h)))
(defn float area ((Shape s))
  (match s
    (Circle (r)   (return (* 3.14f r r)))
    (Rect   (w h) (return (* w h)))))
;==EXPECTED==
typedef enum geo_u002F_Shape_u002F_tag { geo_u002F_Shape_u002F_Circle, geo_u002F_Shape_u002F_Rect } geo_u002F_Shape_u002F_tag;

typedef struct geo_u002F_Shape_u002F_Circle_u002F_p {
  float r;
} geo_u002F_Shape_u002F_Circle_u002F_p;

typedef struct geo_u002F_Shape_u002F_Rect_u002F_p {
  float w;
  float h;
} geo_u002F_Shape_u002F_Rect_u002F_p;

typedef struct geo_u002F_Shape {
  geo_u002F_Shape_u002F_tag tag;
  union geo_u002F_Shape_u002F_u {
  geo_u002F_Shape_u002F_Circle_u002F_p Circle;
  geo_u002F_Shape_u002F_Rect_u002F_p Rect;
} u;
} geo_u002F_Shape;

int geo_u002F_Shape_u002F_Circle_u003F_(geo_u002F_Shape s)
{
  return s.tag == geo_u002F_Shape_u002F_Circle;
}

int geo_u002F_Shape_u002F_Rect_u003F_(geo_u002F_Shape s)
{
  return s.tag == geo_u002F_Shape_u002F_Rect;
}

float geo_u002F_area(geo_u002F_Shape s)
{
  switch (s.tag) {
    case geo_u002F_Shape_u002F_Circle:
      {
        float r = s.u.Circle.r;
        return 3.14f * r * r;
        break;
      }
    case geo_u002F_Shape_u002F_Rect:
      {
        float w = s.u.Rect.w;
        float h = s.u.Rect.h;
        return w * h;
        break;
      }
    default:
      __builtin_unreachable();
  }
}
