; slot* can list several slots at once; every unbound one is reported.
(include <stdio.h>)
(defn void emit ((:* :const char m))
  (slot* *out* *prefix*)
  (fprintf *out* "%s%s\n" *prefix* m))
(defn int main ()
  (emit "hi")
  (return 0))
;==EXPECTED-ERROR==
<stdin>:7:4: error[analysis]: emit requires the dynamic slot *out*, which is unbound here — provide it before the call with (with *out* <value> ...)
  (emit "hi")
   ^

<stdin>:7:4: error[analysis]: emit requires the dynamic slot *prefix*, which is unbound here — provide it before the call with (with *prefix* <value> ...)
  (emit "hi")
   ^
