; loop/recur/break-loop: named recursion point compiled to a labelled goto block.
; recur rebinds in parallel through temps; break-loop jumps past the loop.
(defn int sum-to ((int n))
  (decl (int total) 0)
  (loop ((int i n) (int acc 0))
    (if (zero? i)
      (set total acc)
      (recur (- i 1) (+ acc i))))
  (return total))

(defn int first-neg ((:* int a) (int n))
  (decl (int idx) -1)
  (loop ((int i 0))
    (when (>= i n) (break-loop))
    (when (< (aref a i) 0) (set idx i) (break-loop))
    (recur (+ i 1)))
  (return idx))
;==EXPECTED==
