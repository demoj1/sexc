    int i = n;
    int acc = 0;
    __loop_top_0:
    if (i == 0)
      {
        total = acc;
      }
    else
      {
        {
          int __recur_2 = i - 1;
          int __recur_3 = acc + i;
          i = __recur_2;
          acc = __recur_3;
          goto __loop_top_0;
        }
      }
    __loop_end_1:
    ;
  }
  return total;
}

int first_u002D_neg(int *a, int n)
{
  int idx = -1;
  {
    int i = 0;
    __loop_top_4:
    if (i >= n)
