(defn int sign ((int x))
  (cond
    ((< x 0) (return -1))
    ((> x 0) (return 1))
    (t       (return 0))))
;==EXPECTED==
int sign(int x)
{
  if (x < 0)
    {
      return -1;
    }
  else
    if (x > 0)
      {
        return 1;
      }
    else
      if (t)
        {
          return 0;
        }
}
