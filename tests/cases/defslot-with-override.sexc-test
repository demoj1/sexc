; A defaulted slot can still be rebound by `with` for a dynamic extent; defslot
; owns the single declaration, so `with` emits no second one.
(include <stdio.h>)
(defslot (:* FILE) *out* stdout)
(defn void emit ((:* :const char m)) (fprintf *out* "%s\n" m))
(defn int main ()
  (emit "default sink")
  (with *out* stderr (emit "redirected"))
  (return 0))
;==EXPECTED==
