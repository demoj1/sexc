__attribute__((constructor)) static void sx_defslot_0(void)
{
  _u002A_out_u002A_ = stdout;
}

void emit(const char *m)
{
  fprintf(_u002A_out_u002A_, "%s\n", m);
}

#ifndef SX_WITH_GUARD_

#define SX_WITH_GUARD_

typedef struct __sx_with_guard {
  void *slot;
  const void *saved;
  unsigned long size;
} __sx_with_guard;

