}

#endif

int main(void)
{
  emit("default sink");
  {
    __auto_type sx_with_saved_1 = _u002A_out_u002A_;
    __sx_with_guard sx_with_guard_2 __attribute__((cleanup(__sx_with_restore))) = { &(_u002A_out_u002A_), &sx_with_saved_1, sizeof(_u002A_out_u002A_) };
    _u002A_out_u002A_ = stderr;
    emit("redirected");
  }
  return 0;
}
